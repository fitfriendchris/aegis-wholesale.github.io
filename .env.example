# Aegis Capital — Environment Variables Template
# Copy this file to .env and fill in your real credentials.
# NEVER commit .env to git.

# ── Flask API ──
FLASK_PORT=5001
FLASK_DEBUG=1

# ── SMTP (Gmail App Password recommended) ──
# Used by: daily_runner.py, buyer_blast.py, drip_and_score.py
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
FROM_NAME="Your Name"
REPLY_TO=your.email@gmail.com

# ── Twilio SMS (optional) ──
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM=+15551234567

# ── PropStream / Data API (optional) ──
PROPSTREAM_API_KEY=ps_live_xxxxxxxx
